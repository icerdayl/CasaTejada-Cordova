  "version": "1.0.0",
  "description": "A sample Apache Cordova application that responds to the deviceready event.",
  "main": "index.js",
  "scripts": {
    "css:build": "tailwindcss -i ./www/assets/css/input.css -o ./www/assets/css/style.css",
    "css:watch": "tailwindcss -i ./www/assets/css/input.css -o ./www/assets/css/style.css --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
